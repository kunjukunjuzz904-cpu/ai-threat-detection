# Development Vite Dockerfile
# Hot reload with volume mounts for source code

FROM node:24-alpine

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY frontend/package.json ./
RUN pnpm install

COPY frontend/ .

EXPOSE 5173

CMD ["pnpm", "dev"]
